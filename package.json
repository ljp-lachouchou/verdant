{
  "name": "verdant",
  "version": "0.3.0",
  "description": "Verdant — Multi-agent desktop AI assistant",
  "main": "./out/main/index.js",
  "author": {
    "name": "Verdant",
    "email": "verdant@example.com"
  },
  "license": "MIT",
  "homepage": "https://ljp-lachouchou.github.io/verdant",
  "repository": {
    "type": "git",
    "url": "https://github.com/ljp-lachouchou/verdant.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "package": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux",
    "rebuild": "electron-rebuild -f -w better-sqlite3,node-pty",
    "postinstall": "electron-rebuild -f -w better-sqlite3,node-pty"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.0",
    "better-sqlite3": "^11.0.0",
    "chromium-bidi": "^0.6.0",
    "dotenv": "^17.4.2",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-redux": "^9.1.0",
    "streamdown": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.10",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
